Algoritmo Act2_Lecc7_inciso1_PSeint
	Definir num Como Entero
	Escribir "Servicio Hotel Camino Real"
	Leer num
	
	Si num = 0 Entonces
		Escribir "Llamar a recepcion"
	FinSi
	Si num = 1 Entonces
		Escribir "Llamar a vigilancia"
	FinSi
	Si num = 2 Entonces
		Escribir "Llamar a mantenimiento"
	FinSi
	Si num = 3 Entonces
		Escribir "Llamar a restaurante"
	FinSi
	Si num > 3 Entonces
		Escribir "Error, numero invalido"
	FinSi
FinAlgoritmo
